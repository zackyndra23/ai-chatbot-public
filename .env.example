# Image selection (used by docker-compose)
RAG_REGISTRY_IMAGE=registry.gitlab.com/your-group/your-project
RAG_FLAVOR=cuda
RAG_IMAGE_TAG=__COMMIT_SHA__
RAG_GPU_COUNT=all
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# OpenAI API Key (used for embeddings when EMBEDDINGS_PROVIDER=openai)
OPENAI_API_KEY=

# Claude API Key (Anthropic). ANTHROPIC_API_KEY takes priority over CLAUDE_API_KEY.
CLAUDE_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# === API auth (required — no defaults baked into code) ===
# Generate a UUID for each. The repo includes scripts/generate_api_key.py
# for convenience: `python generate_api_key.py`
API_KEY=
API_HEADER_NAME=x-api-key
SERVICE_AGENT_API_KEY=
SERVICE_AGENT_API_HEADER_NAME=x-service-agent-api-key

# Async summary refresh (post-response)
SUMMARY_ASYNC=on
SUMMARY_ASYNC_DELAY_SEC=0.6
HISTORY_SUMMARY_MAX_TOKENS=160
HISTORY_SUMMARY_MAX_PAIRS=12

# Path to FAQ source file used by ingestion pipelines (supports absolute or relative paths)
SOURCE_FILE=/app/data/faq/sample_acme_faq.json

# MongoDB connection
MONGO_URI=mongodb://<user>:<pass>@<host>:<port>/?authSource=admin
MONGO_DB=faq_automation
DB_CHATBOT=rag_assistant_chatbot

# Crisp integration (optional)
CRISP_SESSIONS_COLL=crisp_sessions
WEBSITE_ID=

# === Calendar / meeting integration (optional) ===
BOOKED_PATH_API=
BEARER_TOKEN_CALENDAR_API=

# === External CRM bridge (optional) ===
# Example: https://n8n.example.com/webhook/<uuid>
MONDAY_PATH=
MONDAY_KEY=
MONDAY_VALUE=

# === Google Sheets (optional — chat-history mirror) ===
GOOGLE_CHAT_HISTORY=off
GOOGLE_CHAT_SHEET_ID=
GOOGLE_CHAT_SHEET_TAB=Chat_History
GOOGLE_SERVICE_ACCOUNT=secrets/sa.json
SA_CLIENT_EMAIL=
SHEET_ID=

# === Prompt sizing ===
# Cap on the rendered prompt sent to the LLM (NOT user-input cap, despite the name).
# Must be ≥ ~8000 when CTX_DOCS_FLOOR=4 so all 4 FAQ chunks fit in the Context section
# without truncation. See docs/ops/env_reference.md for details.
INPUT_MAX_PROMPT=8000

# === RAG retrieval (Phase 1 / Phase 2) ===
# Phase 1 (no service picked): unbiased retrieval, this many candidates.
RETRIEVAL_K=4
# Phase 1 floor (after grader rejection, _pad_to_floor backfills to this).
CTX_DOCS_FLOOR=4
# Phase 2 (after SA_SELECT_* picker click): same-service docs from biased retrieval.
CTX_DOCS_SAME_SERVICE=4
# Phase 2 cross-service backfill — keep at 0 for pure same-service Phase 2.
CTX_DOCS_OTHER_SERVICE=0

# === KB backend (Stage 3A) ===
# Vector-store backend mode for retrieval and build.
# "legacy" — single Chroma collection (pre-3A behavior)
# "split"  — N per-service collections (target steady state)
# "dual"   — both; per-service primary, legacy fallback (migration window only)
KB_BACKEND=legacy

# Fraction of retrieval calls in dual mode that run BOTH backends to log divergence.
# 0.0 = off (default), 0.05 = 5% sampling, 1.0 = every call.
KB_DUAL_AB_SAMPLE_RATE=0.0

# === Redundancy & answer quality (Stage 2026-05-11; default flipped 2026-05-12) ===
#
# REDUNDANCY_METHOD selects the retrieval-side anti-redundancy strategy.
#   mmr        — DEFAULT (recommended). Maximum Marginal Relevance — Chroma
#                rebalances relevance vs diversity using REDUNDANCY_MMR_LAMBDA.
#                Strongest anti-repetition signal in our QA run (2026-05-12):
#                rc_count_final=11 over 3-turn FAQ-RAG flow, +9% latency-FAST
#                vs "normal" on incontext path. Correct recap bypass behaviour.
#   normal     — Runtime kill-switch. Byte-identical to pre-patch behaviour.
#                Use this to disable anti-redundancy entirely (no chunk-id
#                tracking, no Mongo writes, no dedup wrapper). Safe rollback.
#   fuzzy      — rapidfuzz token_set_ratio dedup (rc_count_final=10 in QA).
#                Best when redundancy is lexical (paraphrases share tokens).
#   embedding  — Cosine-similarity dedup (rc_count_final=10 in QA). Best when
#                redundancy is semantic (different wording, same meaning).
#
# How to fill: pick ONE value. Leave blank → falls through to code default ("mmr").
REDUNDANCY_METHOD=mmr

# REDUNDANCY_FUZZY_THRESHOLD — used only when REDUNDANCY_METHOD=fuzzy.
# Range 0..1 (rapidfuzz token_set_ratio normalised). Higher = stricter dedup.
# 0.85 means: drop a chunk if its token-set overlap with an already-kept chunk
# is ≥85%. Lower this to 0.75 if you see too many surviving paraphrases.
REDUNDANCY_FUZZY_THRESHOLD=0.85

# REDUNDANCY_EMBEDDING_THRESHOLD — used only when REDUNDANCY_METHOD=embedding.
# Range 0..1 (cosine similarity). Higher = stricter dedup. 0.92 is empirically
# permissive (only catches near-paraphrases). Lower to 0.85 for more aggressive
# semantic dedup at the cost of recall.
REDUNDANCY_EMBEDDING_THRESHOLD=0.92

# REDUNDANCY_MMR_LAMBDA — used only when REDUNDANCY_METHOD=mmr.
# Range 0..1. 1.0 = pure relevance (no diversification), 0.0 = pure diversity.
# 0.7 leans toward relevance while still injecting diversity. Lower to 0.5 if
# you want more aggressive diversification at risk of weaker recall.
REDUNDANCY_MMR_LAMBDA=0.7

# REDUNDANCY_MMR_FETCH_K_MULTIPLIER — fetch_k = k × multiplier (k=CTX_DOCS_FLOOR).
# Larger pool = MMR has more candidates to diversify from. Default 2 → over-fetch
# 8 candidates to pick top-4. Raising to 3 trades latency for diversity.
REDUNDANCY_MMR_FETCH_K_MULTIPLIER=2

# REDUNDANCY_RECENT_CHUNKS_WINDOW — rolling-window length in turns.
# Total tracked chunk IDs = window × CTX_DOCS_FLOOR (default 5 × 4 = 20 IDs).
# Raise to 10 for longer-context sessions; lower to 3 for short conversations.
REDUNDANCY_RECENT_CHUNKS_WINDOW=5

# REDUNDANCY_RECENT_CHUNKS_SPILLOVER — extra over-fetch when recent_chunk_ids
# is non-empty. Default 2 → fetch CTX_DOCS_FLOOR+2 candidates so the filter has
# headroom. Raise if you see "demoted stale" chunks appearing in Context often.
REDUNDANCY_RECENT_CHUNKS_SPILLOVER=2

# REDUNDANCY_RECAP_BYPASS — when true, "ulangi" / "say that again" / "répétez"
# style requests skip the recent-chunks filter entirely (user explicitly wants
# the prior answer). Set false ONLY if you want recaps to also get fresh chunks.
REDUNDANCY_RECAP_BYPASS=true

# === Qualification method toggle (Stage 2026-05-12) ===
#
# QUALIFICATION_METHOD selects how the chatbot collects qualification info
# during SA flows (after user clicks SA_SELECT picker for a service).
#
#   two_decision_tree   — DEFAULT. Existing 2-agent decision-tree flow:
#                          Agent 1 (intent_type) classifies user reply as
#                          question_only / answer_only / answer_and_question;
#                          Agent 2 (intent_interest) classifies valid / invalid /
#                          uninterested. Questions asked in fixed FLOW_REGISTRY
#                          order. Byte-identical to pre-Stage-4 behavior.
#
#   natural_qualification — Single-agent natural-conversation collector. Same
#                            FLOW_REGISTRY fields, different journey order
#                            (agent decides what to ask next based on context).
#                            Offers meeting picker proactively when minimum-set
#                            of fields collected + user shows buying intent.
#                            Anti-loop rescue: if same field is targeted 3 turns
#                            without commit, fallback to verbatim FLOW_REGISTRY
#                            text wrapped in soft-bridge phrasing. If rescue
#                            still fails → skip field + mark in lead profile.
#
# How to fill: pick ONE value. Leave blank → falls through to "two_decision_tree".
# Method is locked per session at first SA continuation dispatch — flipping
# env mid-session does NOT affect in-flight sessions.
QUALIFICATION_METHOD=natural_qualification


# ====================================================================
# OOC Engine (Stage 0 — 2026-05-13)
# See docs/superpowers/specs/2026-05-13-ooc-response-engine-design.md §6.3
# ====================================================================

# Master switch for the OOC handler. Set to "off" to disable OOC classification
# entirely; messages fall straight through to the existing dispatcher.
OOC_AGENT_ENABLED=on

# Classifier mode:
#   keyword — strict keyword-bank matching only, no LLM call (cheapest, lowest recall)
#   hybrid  — keyword first; LLM fallback for fuzzy categories (recommended)
#   llm     — LLM for all classification (highest cost)
OOC_MODE=hybrid

# Minimum number of keyword hits required to fire a keyword-strict category.
OOC_MIN_KEYWORD_HITS=1

# Minimum text length (chars after strip) before classifier runs. Below this,
# UNCLEAR is returned automatically.
OOC_MIN_TEXT_LEN=3

# Routing URLs for OOC-FREELANCE / OOC-PARTNERSHIP cold-start templates.
# Pre-Stage-0 knobs retained (also consumed directly by modules/out_of_context/ooc_policies.py).
OOC_FREELANCER_URL=https://www.acmeservices.example.com/freelancer/
OOC_PARTNER_URL=https://www.acmeservices.example.com/partner/

# Number of consecutive OOC turns before the human-handover escalation fires
# (default 3 — escalates ON the 3rd consecutive OOC turn).
OOC_ESCALATION_THRESHOLD=3

# Per-user-message countdown applied after escalation. While this counter is
# > 0, OOC classification is skipped and the message falls through to the
# regular dispatcher. The counter decrements by 1 per user message.
OOC_ESCALATION_SUPPRESSION_TURNS=3

# LLM-classifier confidence floor. Below this, the result is treated as
# "no OOC" and the message passes through to the dispatcher.
OOC_LLM_CONFIDENCE_FLOOR=0.6

# OOC-CATCHALL category needs a higher confidence floor than the general
# LLM floor — misclassifying on-topic-but-uncovered as CATCHALL is worse
# UX than letting it through as UNCLEAR / fallthrough.
OOC_CATCHALL_FLOOR=0.7

# Confidence assigned to strict keyword-bank matches.
OOC_KEYWORD_CONFIDENCE=0.95

# Language-detection confidence floor. Below this, the orchestrator falls
# back to session_fallback_language (state-persisted "last confident" lang).
OOC_LANG_DETECTION_FLOOR=0.85

# CSV of service IDs that trigger the high-stakes mid-flow shape (adds P4
# escalation paragraph with senior contact / urgent routing).
OOC_HIGH_STAKES_SERVICES=compliance_audit,claim_review,asset_verification,contact_verification

# CSV of allowed locales. Empty = all 17 canonical langs (id, ms, en, fr, de,
# it, pt, es, vi, th, da, zh, ja, ru, ko, tl, ar) allowed.
OOC_ALLOWED_LOCALES=

# Post-hoc classifier (Refinement #3 — Phase 1 empirical tuning).
# Default disabled. When enabled, samples a fraction of suppression-fallthrough
# turns and runs a cheap classifier post-hoc to log what "would have been"
# classified — used to tune the suppression behavior.
OOC_POSTHOC_CLASSIFIER_ENABLED=false
OOC_POSTHOC_CLASSIFIER_SAMPLE_RATE=0.1
OOC_POSTHOC_CLASSIFIER_MODE=keyword
